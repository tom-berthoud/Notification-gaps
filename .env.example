GAPS_LOGIN_USERNAME="prenom.nom@heig-vd.ch"
GAPS_LOGIN_PASSWORD="change-me"

# Optional (defaults to https://gaps.heig-vd.ch)
# GAPS_URL="https://gaps.heig-vd.ch"

# Where the scraper stores its local history (used to detect new/updated grades)
# GAPS_HISTORY_GRADES_FILE="$HOME/.config/gaps-cli/grades-history.json"

# Either a notifier API base URL (ex: https://my-server.example) OR a Discord webhook URL
GAPS_SCRAPER_API_URL="https://discord.com/api/webhooks/XXXX/YYYY"

# Optional second Discord webhook URL
# GAPS_SCRAPER_API_URL2="https://discord.com/api/webhooks/XXXX/YYYY"

# Only used when GAPS_SCRAPER_API_URL is a notifier API (not Discord)
# GAPS_SCRAPER_API_KEY=""
