# ── Identifiants HEIG-VD ────────────────────────────────────────────────────
GAPS_LOGIN_USERNAME="prenom.nom"
GAPS_LOGIN_PASSWORD="ton-mot-de-passe"

# ── Bot Discord ──────────────────────────────────────────────────────────────
GAPS_DISCORD_BOT_TOKEN="ton-token-bot-discord"
GAPS_DISCORD_CHANNEL_ID="id-du-channel-notifications"
GAPS_DISCORD_GUILD_ID="id-du-serveur-discord"

# ── Configuration études ─────────────────────────────────────────────────────
# Année académique de ta première rentrée (ex: 2024 pour rentrée 2024-2025)
GAPS_STUDY_START_YEAR="2024"

# ── Optionnel ────────────────────────────────────────────────────────────────
# URL de GAPS (par défaut : https://gaps.heig-vd.ch)
# GAPS_URL="https://gaps.heig-vd.ch"

# Fichier d'historique des notes
# GAPS_HISTORY_GRADES_FILE="/tmp/grades-history.json"

# Intervalle de vérification en secondes (par défaut : 600 = 10 min)
# GAPS_BOT_INTERVAL=600
